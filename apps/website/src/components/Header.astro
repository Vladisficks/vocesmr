---
import { Icon } from "astro-icon/components";
const currentPath = Astro.url.pathname;
const aboutHref = currentPath === "/" ? "#aboutUs" : "/#aboutUs";
---

<header class="header" id="header">
  <div class="header__container">
    <a href="/" class="header__logo">
      <img src="https://placehold.co/250x100" alt="Logo VocesMR" />
    </a>

    <button
      class="header__menu-toggle"
      id="menuToggle"
      type="button"
      aria-label="Abrir menú"
      aria-expanded="false"
      aria-controls="nav"
    >
      <Icon
        name="material-symbols:menu-rounded"
        class="icon-menu"
        aria-hidden="true"
      />
      <Icon
        name="material-symbols:close-rounded"
        class="icon-close"
        aria-hidden="true"
      />
    </button>

    <nav class="header__nav" id="nav" aria-label="Navegación principal">
      <div class="header__nav-content">
        <div class="header__nav-links">
          <a href="/" class="header__link">INICIO</a>
          <a href="/locutores" class="header__link">LOCUTORES</a>
          <a href={aboutHref} class="header__link">NOSOTROS</a>
        </div>

        <a href="#contactUs" class="header__cta">Solicita tu Casting</a>
      </div>
    </nav>
  </div>
</header>
<div class="header__backdrop" id="backdrop"></div>

<style>
  /* ============ Header ============ */
  .header {
    position: fixed;
    inset: 0.75rem 0.75rem auto 0.75rem;
    z-index: var(--z-header);
    border-radius: calc(8px + 0.5rem);
    background-color: rgba(31, 31, 36, 0);
    transition:
      background-color var(--transition-speed) var(--transition-ease),
      transform 0.3s var(--transition-ease);
  }

  .header.is-hidden {
    transform: translateY(calc(-100% - 0.75rem));
  }

  .header.is-open,
  .header.is-scrolled {
    background-color: rgba(31, 31, 36, 0.95);
  }

  .header__container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.5rem;
  }

  /* ============ Logo ============ */
  .header__logo {
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 1;
  }

  .header__logo img {
    height: 2.5rem;
    width: auto;
    object-fit: contain;
    border-radius: 10px;
  }

  /* ============ Menu toggle ============ */
  .header__menu-toggle {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 2.75rem;
    width: 2.75rem;
    flex-shrink: 0;
    padding: 0;
    border-radius: 8px;
    background: none;
    border: none;
    color: var(--text-primary);
    cursor: pointer;
    transition: background-color var(--transition-speed) var(--transition-ease);
  }

  .header__menu-toggle:hover {
    background-color: rgba(255, 255, 255, 0.08);
  }

  .header__menu-toggle:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  .icon-menu,
  .icon-close {
    position: absolute;
    height: 2rem;
    width: 2rem;
    transition:
      opacity var(--transition-speed) var(--transition-ease),
      transform var(--transition-speed) var(--transition-ease);
  }

  .icon-menu {
    opacity: 1;
    transform: rotate(0deg);
  }

  .header__menu-toggle[aria-expanded="true"] .icon-menu {
    opacity: 0;
    transform: rotate(90deg);
  }

  .icon-close {
    opacity: 0;
    transform: rotate(-90deg);
  }

  .header__menu-toggle[aria-expanded="true"] .icon-close {
    opacity: 1;
    transform: rotate(0deg);
  }

  /* ============ Navigation ============ */
  .header__nav {
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    right: 0;
    z-index: var(--z-header);
    padding: 1rem;
    background-color: rgba(31, 31, 36, 0.95);
    border-radius: calc(8px + 0.5rem);
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transform: translateY(-10px);
    transition:
      opacity var(--transition-speed) var(--transition-ease),
      visibility var(--transition-speed) var(--transition-ease),
      transform var(--transition-speed) var(--transition-ease);
  }

  .header__nav.is-open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
  }

  .header__nav-content {
    display: flex;
    flex-direction: column;
    width: 100%;
  }

  .header__nav-links {
    display: flex;
    flex-direction: column;
    width: 100%;
    padding-bottom: 1.2rem;
  }

  .header__link {
    width: 100%;
    padding: 0.75rem 0;
    text-align: center;
    font-size: var(--fs-base);
    font-weight: 500;
    letter-spacing: var(--ls-caps);
    transition: color var(--transition-speed) var(--transition-ease);
  }

  .header__link:hover {
    color: var(--text-muted);
  }

  .header__link:active {
    color: var(--text-muted);
  }

  .header__link:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
    border-radius: 4px;
    color: var(--text-primary);
  }

  .header__cta {
    width: 100%;
    padding: 0.625rem 1rem;
    text-align: center;
    font-family: var(--font-heading);
    font-size: var(--fs-base);
    font-weight: 700;
    background-color: var(--accent-primary);
    border-radius: 8px;
    box-shadow: var(--shadow-press);
    transition:
      background-color var(--transition-speed) var(--transition-ease),
      transform var(--transition-speed) var(--transition-ease),
      box-shadow var(--transition-speed) var(--transition-ease);
  }

  .header__cta:hover {
    background-color: var(--accent-hover);
    transform: translateY(-1px);
    box-shadow: var(--shadow-press-hover);
  }

  .header__cta:active {
    transform: translateY(2px);
    box-shadow: 0 1px 0 color-mix(in srgb, var(--accent-primary) 60%, #000000);
  }

  /* ============ Backdrop ============ */
  .header__backdrop {
    position: fixed;
    inset: 0;
    z-index: var(--z-backdrop);
    background-color: rgba(0, 0, 0, 0);
    backdrop-filter: blur(0);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity var(--transition-speed) var(--transition-ease),
      backdrop-filter var(--transition-speed) var(--transition-ease),
      background-color var(--transition-speed) var(--transition-ease);
  }

  .header__backdrop.is-visible {
    background-color: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    opacity: 1;
    pointer-events: auto;
  }

  /* ============ Responsive ============ */
  @media (min-width: 768px) {
    .header {
      inset: 0.75rem 2rem auto 2rem;
    }

    .header__container {
      justify-content: flex-start;
      padding: 0.75rem;
      gap: 2rem;
    }

    .header__logo img {
      height: 3rem;
      flex-shrink: 0;
    }

    .header__menu-toggle {
      display: none;
    }

    .header__nav {
      position: static;
      padding: 0;
      left: auto;
      right: auto;
      flex: 1;
      background-color: transparent;
      backdrop-filter: none;
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
      transform: none;
    }

    .header__nav-content {
      flex-direction: row;
      align-items: center;
      justify-content: center;
      gap: 2rem;
    }

    .header__nav-links {
      flex-direction: row;
      justify-content: center;
      padding-bottom: 0;
      gap: 2rem;
    }

    .header__link {
      width: auto;
      padding: 0.5rem 0;
    }

    .header__cta {
      width: auto;
      flex-shrink: 0;
      padding: 0.625rem 1.5rem;
    }
  }
</style>

<script>
  const header = document.getElementById("header");
  const menuToggle = document.getElementById("menuToggle");
  const nav = document.getElementById("nav");
  const backdrop = document.getElementById("backdrop");

  // ============= Open / Close menu =============
  function openMenu() {
    menuToggle?.setAttribute("aria-expanded", "true");
    menuToggle?.setAttribute("aria-label", "Cerrar menú");
    nav?.classList.add("is-open");
    header?.classList.add("is-open");
    backdrop?.classList.add("is-visible");
  }

  function closeMenu() {
    menuToggle?.setAttribute("aria-expanded", "false");
    menuToggle?.setAttribute("aria-label", "Abrir menú");
    nav?.classList.remove("is-open");
    header?.classList.remove("is-open");
    backdrop?.classList.remove("is-visible");
  }

  function toggleMenu() {
    const isOpen = menuToggle?.getAttribute("aria-expanded") === "true";
    if (isOpen) closeMenu();
    else openMenu();
  }

  if (window.innerWidth >= 768) closeMenu();

  menuToggle?.addEventListener("click", toggleMenu);

  nav?.addEventListener("click", (event) => {
    const target = event.target as HTMLElement;
    if (target.closest("a")) setTimeout(closeMenu, 150);
  });

  backdrop?.addEventListener("click", closeMenu);

  // ============= Scroll effect =============
  const SCROLL_THRESHOLD = 80;
  let lastScrollY = window.scrollY;

  window.addEventListener(
    "scroll",
    () => {
      const currentScrollY = window.scrollY;
      const menuIsOpen = menuToggle?.getAttribute("aria-expanded") === "true";

      // Scroll effect: fondo visible
      if (currentScrollY > 20) header?.classList.add("is-scrolled");
      else header?.classList.remove("is-scrolled");

      // Hide/show: solo actúa si el menú está cerrado
      if (!menuIsOpen) {
        if (currentScrollY > lastScrollY && currentScrollY > SCROLL_THRESHOLD) {
          // Scrolleando hacia abajo y ya pasamos el umbral → esconder
          header?.classList.add("is-hidden");
        } else {
          // Scrolleando hacia arriba (o arriba del umbral) → mostrar
          header?.classList.remove("is-hidden");
        }
      }

      lastScrollY = currentScrollY;
    },
    { passive: true },
  );

  // ============= Close when back to desktop =============
  window.addEventListener("resize", () => {
    if (window.innerWidth >= 768) closeMenu();
  });
</script>
