---
const {
  eyebrow = "Voces MR | Agencia de Locutores Comerciales",
  title = ["La", "voz", "que hace que te", "escuchen"],
  subtitle = "Conectamos marcas con el talento correcto",
  primaryHref = "#contactUs",
  primaryLabel = "Encuentra tu voz",
  secondaryHref = "/locutores",
  secondaryLabel = "Explorar locutores",
} = Astro.props;
---

<section class="hero" id="hero">
  <div class="hero__inner">
    <div class="hero__content">
      <p class="hero__eyebrow">{eyebrow}</p>

      <h1 class="hero__title">
        {title[0]}
        <span>{title[1]}</span>
        {title[2]}
        <span>{title[3]}</span>
      </h1>

      <p class="hero__subtitle">{subtitle}</p>

      <div class="hero__buttons">
        <a href={primaryHref} class="btn btn-primary">{primaryLabel}</a>
        <a href={secondaryHref} class="btn btn-secondary">{secondaryLabel}</a>
      </div>
    </div>

    <div class="hero__art" aria-hidden="true">
      <span class="hero__pulse hero__pulse--1"></span>
      <span class="hero__pulse hero__pulse--2"></span>
      <span class="hero__pulse hero__pulse--3"></span>
      <span class="hero__hex"></span>
    </div>
  </div>
</section>

<style>
  .hero {
    min-height: 100dvh;
    padding-top: var(--header-h);
    overflow: clip;
  }

  .hero__inner {
    width: min(100%, var(--container-max));
    min-height: calc(100dvh - var(--header-h));
    margin-inline: auto;
    display: grid;
    grid-template-areas:
      "content"
      "art";
    grid-template-rows: minmax(0, 1fr) minmax(14rem, 38vw);
    align-items: center;
  }

  .hero__content {
    grid-area: content;
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: clamp(0.75rem, 2vw, 1.2rem);
    padding: clamp(1rem, 4vw, 3rem) clamp(1rem, 4vw, 4rem);
  }

  .hero__eyebrow {
    font-size: clamp(0.72rem, 0.6rem + 0.3vw, 0.85rem);
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .hero__title {
    max-width: 12ch;
    font-size: clamp(2.25rem, 6.5vw, 4.75rem);
    font-weight: 700;
    line-height: 0.98;
    text-wrap: balance;
  }

  .hero__title span {
    color: var(--accent-primary);
  }

  .hero__subtitle {
    max-width: 30ch;
    font-size: clamp(1rem, 1vw + 0.75rem, 1.2rem);
    line-height: 1.55;
    color: color-mix(in srgb, var(--text-primary) 88%, #ffffff);
  }

  .hero__buttons {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.85rem;
    margin-top: 0.25rem;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    width: 75%;
    padding: 0.9rem 1.1rem;
    border-radius: var(--radius-md);
    font-size: 0.98rem;
    font-weight: 700;
    text-align: center;
    transition:
      transform 0.15s ease,
      background-color 0.2s ease,
      color 0.2s ease,
      box-shadow 0.15s ease,
      border-color 0.2s ease;
    box-shadow: var(--shadow-press);
  }

  .btn:active {
    transform: translateY(2px);
    box-shadow: 0 1px 0 color-mix(in srgb, var(--accent-primary) 60%, #000000);
  }

  .btn-primary {
    background-color: var(--accent-primary);
    color: var(--text-primary);
  }

  .btn-secondary {
    border: 2px solid var(--accent-primary);
    background: transparent;
    color: var(--accent-primary);
  }

  .hero__art {
    --hex-size: clamp(18rem, 74vw, 34rem);
    grid-area: art;
    position: relative;
    isolation: isolate;
    min-height: clamp(15rem, 38vw, 24rem);
    pointer-events: none;
  }

  .hero__hex,
  .hero__pulse {
    position: absolute;
    right: clamp(-9rem, -11vw, -4rem);
    bottom: clamp(-7rem, -10vw, -2rem);
    width: var(--hex-size);
    aspect-ratio: 1;
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
  }

  .hero__hex {
    background: var(--accent-primary);
    z-index: 2;
  }

  .hero__pulse {
    background: rgba(193, 18, 31, 0.2);
    z-index: 1;
    opacity: 0;
    animation: pulse 3s ease-out infinite;
    will-change: transform, opacity;
  }

  .hero__pulse--1 {
    animation-delay: 0s;
  }
  .hero__pulse--2 {
    animation-delay: 0.45s;
  }
  .hero__pulse--3 {
    animation-delay: 0.9s;
  }

  @keyframes pulse {
    0% {
      opacity: 0.6;
      transform: scale(1);
    }
    70%,
    100% {
      opacity: 0;
      transform: scale(1.45);
    }
  }

  @media (min-width: 768px) {
    .hero__inner {
      grid-template-areas: "content art";
      grid-template-columns: minmax(0, 1.1fr) minmax(18rem, 0.9fr);
      grid-template-rows: 1fr;
    }

    .hero__buttons {
      flex-direction: row;
    }

    .btn {
      width: auto;
      padding-inline: 1.35rem;
    }

    .hero__art {
      --hex-size: clamp(20rem, 34vw, 30rem);
    }

    .hero__hex,
    .hero__pulse {
      inset: 0;
      margin: auto;
    }
  }

  @media (hover: hover) and (pointer: fine) {
    .btn-primary:hover {
      background-color: var(--accent-hover);
      transform: translateY(-1px);
      box-shadow: var(--shadow-press-hover);
    }

    .btn-secondary:hover {
      background-color: var(--accent-primary);
      color: var(--text-primary);
      transform: translateY(-1px);
      box-shadow: var(--shadow-press-hover);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero__pulse {
      animation: none;
    }

    .btn {
      transition: none;
    }
  }
</style>
