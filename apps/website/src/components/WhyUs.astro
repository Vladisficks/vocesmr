---
import { Icon } from "astro-icon/components";
---

<section class="whyUs" id="whyUs">
  <div class="whyUs__container">
    <div class="whyUs__sections">
      <div class="whyUs__section">
        <div class="whyUs__card">
          <Icon name="material-symbols:diamond-rounded" class="whyUs__icon" />
          <h2>Selección Curada</h2>
          <p>
            Analizamos y seleccionamos las voces que mejor se alinean con los
            objetivos de tu proyecto
          </p>
        </div>
      </div>
      <div class="whyUs__section">
        <div class="whyUs__card">
          <Icon name="material-symbols:handshake-rounded" class="whyUs__icon" />
          <h2>Trato Directo y Personal</h2>
          <p>
            Acompañamos cada proyecto de principio a fin con atención cercana y
            seguimiento constante
          </p>
        </div>
      </div>
      <div class="whyUs__section">
        <div class="whyUs__card">
          <Icon name="material-symbols:rocket-rounded" class="whyUs__icon" />
          <h2>Entrega sin Fricciones</h2>
          <p>
            Nos encargamos de la coordinación, seguimiento y tiempos de entrega.
            Tú solo eliges la voz adecuada
          </p>
        </div>
      </div>
      <div class="whyUs__section">
        <div class="whyUs__card">
          <Icon name="material-symbols:globe" class="whyUs__icon" />
          <h2>Variedad de Voces</h2>
          <p>
            Contamos con voces para distintos estilos, idiomas y mercados.
            Encuentra el talento adecuado sin importar el alcance de tu campaña
          </p>
        </div>
      </div>
    </div>
  </div>
</section>  

<style>
  :root {
    --card-shadow-offset: 14px;
  }

  .whyUs__container {
    padding: 2.5rem clamp(1.5rem, 5vw, 6rem);
  }

  .whyUs__sections {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2.5rem;
    padding-inline-end: var(--card-shadow-offset);
    padding-block-end: var(--card-shadow-offset);
  }

  .whyUs__section {
    position: relative;
  }

  .whyUs__section::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 12px;
    background-color: var(--accent-primary);
    transform: translate(6px, 6px);
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .whyUs__card {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    height: 100%;
    padding: 2rem;
    background-color: var(--bg-surface);
    border-radius: 12px;
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .whyUs__section:hover .whyUs__card {
    transform: translate(-4px, -4px);
  }

  .whyUs__section:hover::before {
    transform: translate(var(--card-shadow-offset), var(--card-shadow-offset));
  }

  .whyUs__card h2 {
    font-size: var(--fs-md);
    font-weight: 700;
    color: var(--text-primary);
    letter-spacing: var(--ls-caps);
  }

  .whyUs__card p {
    font-size: var(--fs-base);
    color: var(--text-muted);
    font-weight: 500;
  }

  .whyUs__icon {
    width: clamp(2rem, 5vw, 3rem);
    height: clamp(2rem, 5vw, 3rem);
    color: var(--accent-primary);
    transition:
      transform 0.35s cubic-bezier(0.22, 1, 0.36, 1),
      color 0.35s ease;
  }

  .whyUs__section:hover .whyUs__icon {
    transform: scale(1.12) rotate(-6deg);
    color: var(--accent-hover);
  }

  .whyUs__sections.is-animated .whyUs__section {
    opacity: 0;
    transform: translateY(28px);
    transition:
      opacity 0.6s ease,
      transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .whyUs__sections.is-animated .whyUs__section.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .whyUs__sections.is-animated .whyUs__section:nth-child(1) { transition-delay: 0s; }
  .whyUs__sections.is-animated .whyUs__section:nth-child(2) { transition-delay: 0.08s; }
  .whyUs__sections.is-animated .whyUs__section:nth-child(3) { transition-delay: 0.16s; }
  .whyUs__sections.is-animated .whyUs__section:nth-child(4) { transition-delay: 0.24s; }

  @media (min-width: 768px) {
    .whyUs__sections {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-auto-rows: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .whyUs__section::before,
    .whyUs__card,
    .whyUs__icon,
    .whyUs__sections.is-animated .whyUs__section {
      transition: none;
    }
    .whyUs__sections.is-animated .whyUs__section {
      opacity: 1;
      transform: none;
    }
  }
</style>

<script>
  const sections = document.querySelector(".whyUs__sections");
  const prefersReduced = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (sections && !prefersReduced) {
    sections.classList.add("is-animated");

    const cards = sections.querySelectorAll(".whyUs__section");
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.2 },
    );

    cards.forEach((card) => observer.observe(card));
  }
</script>