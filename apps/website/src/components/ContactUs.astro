---
import { Icon } from "astro-icon/components";
---

<section class="contactUs" id="contactUs">
  <div class="contactUs__container">
    <div class="contactUs__details">
      <h2 class="contactUs__title">Contáctanos</h2>
      <h3 class="contactUs__subtitle">Háblanos sobre tu proyecto</h3>
      <p class="contactUs__description">
        Escríbenos y encontraremos la voz perfecta para tu campaña
      </p>

      <address class="contactUs__address">
        <div class="contactUs__info">
          <div class="contactUs__icon-wrapper" aria-hidden="true">
            <Icon name="material-symbols:mail" class="contactUs__icon" />
          </div>
          <div class="contactUs__info-text">
            <span class="contactUs__info-label">Email</span>
            <a
              href="mailto:monica.reyes.locutores@gmail.com"
              class="contactUs__info-link"
            >
              monica.reyes@vocesmr.com
            </a>
          </div>
        </div>

        <div class="contactUs__info">
          <div class="contactUs__icon-wrapper" aria-hidden="true">
            <Icon
              name="material-symbols:phone-in-talk"
              class="contactUs__icon"
            />
          </div>
          <div class="contactUs__info-text">
            <span class="contactUs__info-label">Teléfono</span>
            <a href="tel:+525537077261" class="contactUs__info-link">
              +52 55 3707 7261
            </a>
          </div>
        </div>
      </address>
    </div>

    <div class="contactUs__mock-divider"></div>

    <form class="contactUs__form" action="/contact" method="post">
      <div class="contactUs__form-input">
        <label for="full-name">NOMBRE</label>
        <input type="text" name="full-name" id="full-name" required />
      </div>

      <div class="contactUs__form-input">
        <label for="company">EMPRESA / MARCA</label>
        <input type="text" name="company" id="company" required />
      </div>

      <div class="contactUs__form-input">
        <label for="email">EMAIL</label>
        <input type="email" name="email" id="email" required />
      </div>

      <div class="contactUs__form-input">
        <label for="message">MENSAJE</label>
        <textarea name="message" id="message" rows="5" required></textarea>
      </div>

      <button class="contactUs__form-submit" type="submit"
        >Enviar mensaje</button
      >
    </form>
  </div>
</section>

<style>
  .contactUs {
    padding: 1.2rem;
  }

  .contactUs__container {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
  }

  .contactUs__details {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    align-items: center;
  }

  .contactUs__title {
    font-size: var(--fs-lg);
    font-weight: 700;
    color: var(--accent-primary);
  }

  .contactUs__subtitle {
    padding-top: 1rem;
    font-size: var(--fs-md);
  }

  .contactUs__description {
    font-size: var(--fs-base);
    font-weight: 400;
    color: var(--text-muted);
    text-align: center;
  }

  .contactUs__address {
    display: flex;
    flex-direction: column;
    padding-top: 1.5rem;
    gap: 0.75rem;
    font-style: normal;
  }

  .contactUs__info {
    display: flex;
    flex-direction: row;
    gap: 0.75rem;
  }

  .contactUs__icon-wrapper {
    display: flex;
    align-items: center;
    justify-content: center;
    align-self: stretch;
    background-color: var(--accent-primary);
    box-shadow: var(--shadow-press);
    border-radius: 8px;
    width: clamp(2.05rem, 4vw, 2.55rem);
  }

  .contactUs__icon {
    width: clamp(1.1rem, 2.2vw, 1.4rem);
    height: clamp(1.1rem, 2.2vw, 1.4rem);
    color: var(--text-primary);
  }

  .contactUs__info-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
    min-width: 0;
  }

  .contactUs__info-label {
    font-size: var(--fs-sm);
    font-weight: 500;
    color: var(--text-muted);
  }

  .contactUs__info-link {
    font-size: var(--fs-base);
    font-weight: 400;
    overflow-wrap: break-word;
    word-break: break-all;
  }

  .contactUs__mock-divider {
    height: 4px;
    background: var(--bg-surface);
    border-radius: 2px;
  }

  .contactUs__form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contactUs__form-input {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contactUs__form-input label {
    font-size: var(--fs-sm);
    font-weight: 600;
    color: var(--text-muted);
  }

  .contactUs__form-input input,
  textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: var(--fs-base);
    font-weight: 400;
    background-color: var(--bg-surface);
    color: var(--text-primary);
    border: 1px solid #333;
    border-radius: 8px;
    resize: none;
  }

  .contactUs__form-input input:focus-visible,
  .contactUs__form-input textarea:focus-visible {
    outline: none;
    border-color: var(--accent-primary);
    box-shadow: var(--focus-ring);
  }

  .contactUs__form-submit {
    padding: 0.625rem 1rem;
    text-align: center;
    background-color: var(--accent-primary);
    color: var(--text-primary);
    font-family: var(--font-heading);
    font-size: var(--fs-base);
    font-weight: 700;
    border: none;
    border-radius: 8px;
    box-shadow: var(--shadow-press);
  }

  .contactUs__form-submit:hover {
    background-color: var(--accent-hover);
    transform: translateY(-1px);
    box-shadow: var(--shadow-press-hover);
  }

  .contactUs__form-submit:active {
    transform: translateY(2px);
    box-shadow: 0 1px 0 color-mix(in srgb, var(--accent-primary) 60%, #000000);
  }

  /* ============ Respons{ive ============ */
  @media (min-width: 768px) {
    .contactUs__container {
      flex-direction: row;
      justify-content: space-between;
    }

    .contactUs__details {
      align-items: flex-start;
      flex: 1;
    }

    .contactUs__description {
      text-align: left;
    }

    .contactUs__address {
      gap: 1.5rem;
    }

    .contactUs__mock-divider {
      width: 4px;
      height: auto;
      background: var(--bg-surface);
    }

    .contactUs__form {
      flex: 1;
    }

    .contactUs__form-submit {
      width: auto;
      align-self: center;
      padding: 0.625rem 2rem;
    }
  }
</style>
