---
import { Icon } from "astro-icon/components";
---

<section class="howWeWork" id="howWeWork">
  <div class="howWeWork__container">
    <div class="howWeWork__title">
      <h2 class="howWeWork__heading">Cómo Trabajamos</h2>
      <p class="howWeWork__subtitle">
        Desde el primer contacto hasta conectar con el locutor ideal
      </p>
    </div>

    <ol class="howWeWork__steps">
      <li class="howWeWork__step">
        <div class="howWeWork__hexagon">
          <Icon name="material-symbols:chat-rounded" class="howWeWork__icon" />
        </div>
        <div class="howWeWork__description">
          <h3 class="howWeWork__step-title">Cuéntanos tu proyecto</h3>
          <p class="howWeWork__step-text">
            Comparte con nosotros el objetivo de tu campaña, el tono que buscas
            y dónde se utilizará
          </p>
        </div>
      </li>

      <li class="howWeWork__step">
        <div class="howWeWork__hexagon">
          <Icon
            name="material-symbols:person-search-rounded"
            class="howWeWork__icon"
          />
        </div>
        <div class="howWeWork__description">
          <h3 class="howWeWork__step-title">Encontramos tu voz</h3>
          <p class="howWeWork__step-text">
            Elegimos a los locutores ideales para tu campaña y te presentamos
            las mejores opciones
          </p>
        </div>
      </li>

      <li class="howWeWork__step">
        <div class="howWeWork__hexagon">
          <Icon name="material-symbols:link-rounded" class="howWeWork__icon" />
        </div>
        <div class="howWeWork__description">
          <h3 class="howWeWork__step-title">Conectamos ambas partes</h3>
          <p class="howWeWork__step-text">
            Facilitamos el contacto entre cliente y locutor, además de gestionar
            acuerdos y seguimiento durante el proyecto
          </p>
        </div>
      </li>
    </ol>

    <p class="howWeWork__tagline">
      Tú tienes el mensaje. Nosotros encontramos la voz que lo representa
    </p>
  </div>
</section>

<style>
  /* ============ Tokens ============ */
  .howWeWork {
    --hw-hex-size: clamp(80px, 18vw, 130px);
    --hw-hex-ratio: 1.1547; /* hexágono pointy-top: alto = ancho * ratio */
    --hw-line: 3px;
    --hw-step-gap: 3rem; /* gap entre pasos = largo del conector */
    --hw-stagger: 0.2s; /* retraso base entre pasos */

    padding: 2.5rem 1.5rem;
  }

  /* ============ Layout general ============ */
  .howWeWork__container {
    display: grid;
    justify-items: center;
    text-align: center;
    gap: 2.5rem;
    max-width: 960px;
    margin-inline: auto;
  }

  .howWeWork__title {
    display: grid;
    justify-items: center;
    gap: 0.75rem;
  }

  .howWeWork__heading {
    position: relative;
    width: fit-content;
    margin-inline: auto;
    padding-top: 0.75rem;
    font-size: var(--fs-lg);
    font-weight: 700;
    color: var(--accent-primary);
  }

  .howWeWork__heading::before {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 50%; 
    height: 4px;
    background: var(--accent-primary);
    border-radius: 999px;
  }

  .howWeWork__subtitle {
    font-size: var(--fs-base);
    font-weight: 500;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* ============ Step lines ============ */
  .howWeWork__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    width: 100%;
    display: grid;
    gap: var(--hw-step-gap);
    justify-items: center;
  }

  /* ============ Step ============ */
  .howWeWork__step {
    position: relative;
    z-index: 0;
    display: grid;
    justify-items: center;
    gap: 1.5rem;
    text-align: center;
    width: 100%;
  }

  /* ============ Connector ============ */
  .howWeWork__step:not(:last-child)::after {
    content: "";
    position: absolute;
    top: 100%;
    left: 50%;
    width: var(--hw-line);
    height: var(--hw-step-gap);
    background: linear-gradient(to bottom, var(--accent-primary), transparent);
    border-radius: 999px;
    transform: translateX(-50%) scaleY(0);
    transform-origin: top center;
    transition: transform 0.5s ease;
    transition-delay: calc(var(--step-index, 0) * var(--hw-stagger) + 0.45s);
  }

  .howWeWork__step.is-visible:not(:last-child)::after {
    transform: translateX(-50%) scaleY(1);
  }

  /* ============ Hexágono ============ */
  .howWeWork__hexagon {
    position: relative;
    z-index: 1;
    width: var(--hw-hex-size);
    aspect-ratio: 1 / var(--hw-hex-ratio);
    clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);
    background: var(--accent-primary);
    display: grid;
    place-items: center;

    opacity: 0;
    transform: scale(0.8) rotate(-8deg);
    transition:
      opacity 0.5s ease,
      transform 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    transition-delay: calc(var(--step-index, 0) * var(--hw-stagger));
  }

  .howWeWork__step.is-visible .howWeWork__hexagon {
    opacity: 1;
    transform: scale(1) rotate(0);
  }

  .howWeWork__step:hover .howWeWork__hexagon {
    transform: rotate(15deg) scale(1.05);
  }

  /* ============ Icono ============ */
  .howWeWork__icon {
    width: 45%;
    height: 45%;
    color: var(--text-primary);

    opacity: 0;
    transform: scale(0.5);
    transition:
      opacity 0.4s ease,
      transform 0.4s ease;
    transition-delay: calc(var(--step-index, 0) * var(--hw-stagger) + 0.15s);
  }

  .howWeWork__step.is-visible .howWeWork__icon {
    opacity: 1;
    transform: scale(1);
  }

  /* ============ Texto ============ */
  .howWeWork__description {
    display: grid;
    gap: 0.5rem;

    opacity: 0;
    transform: translateY(0.75rem);
    transition:
      opacity 0.5s ease,
      transform 0.5s ease;
    transition-delay: calc(var(--step-index, 0) * var(--hw-stagger) + 0.3s);
  }

  .howWeWork__step.is-visible .howWeWork__description {
    opacity: 1;
    transform: translateY(0);
  }

  .howWeWork__step-title {
    font-size: var(--fs-md);
    font-weight: 700;
    color: var(--accent-primary);
    letter-spacing: var(--ls-caps);
    margin: 0;
    line-height: 1.3;
    min-height: calc(1.3em * 2);
  }

  .howWeWork__step-text {
    font-size: var(--fs-base);
    font-weight: 500;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* ============ Tagline ============ */
  .howWeWork__tagline {
    font-size: var(--fs-base);
    font-weight: 700;
    color: var(--text-primary);
  }

  /* ============ Desktop: solo invertimos la orientación ============ */
  @media (min-width: 768px) {
    .howWeWork__steps {
      grid-auto-flow: column;
      grid-auto-columns: 1fr;
      align-items: start;
    }

    /* Conector horizontal, centrado en el hexágono vía tokens */
    .howWeWork__step:not(:last-child)::after {
      top: calc(var(--hw-hex-size) * var(--hw-hex-ratio) / 2);
      left: 50%;
      width: calc(100% + var(--hw-step-gap));
      height: var(--hw-line);
      background: linear-gradient(to right, var(--accent-primary), transparent);
      transform: translateY(-50%) scaleX(0);
      transform-origin: left center;
    }

    .howWeWork__step.is-visible:not(:last-child)::after {
      transform: translateY(-50%) scaleX(1);
    }
  }

  /* ============ Accesibilidad ============ */
  @media (prefers-reduced-motion: reduce) {
    .howWeWork__hexagon,
    .howWeWork__icon,
    .howWeWork__description {
      opacity: 1;
      transform: none;
      transition: none;
    }

    .howWeWork__step:not(:last-child)::after {
      transition: none;
      transform: translateX(-50%) scaleY(1);
    }

    @media (min-width: 768px) {
      .howWeWork__step:not(:last-child)::after {
        transform: translateY(-50%) scaleX(1);
      }
    }
  }
</style>

<script>
  const steps = document.querySelectorAll<HTMLElement>(".howWeWork__step");

  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        entry.target.classList.add("is-visible");
        observer.unobserve(entry.target);
      }
    },
    { threshold: 0.3 },
  );

  steps.forEach((step, index) => {
    step.style.setProperty("--step-index", String(index));
    observer.observe(step);
  });
</script>
