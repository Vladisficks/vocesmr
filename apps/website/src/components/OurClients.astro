<style>
  .ourClients__container {
    display: flex;
    flex-direction: column;
    background-color: var(--accent-primary);
    padding: 1.5rem;
    gap: 2rem;
  }

  .ourClients-title {
    text-align: center;
    font-size: var(--fs-xl);
    color: var(--text-primary);
  }

  .ourClients__carousel {
    overflow: hidden;
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 10%,
      black 90%,
      transparent 100%
    );
  }

  .ourClients__track {
    display: flex;
    flex-wrap: nowrap;
    width: max-content;
    animation: scroll 55s linear infinite;
    will-change: transform;
  }

  .ourClients__track img {
    height: clamp(1.75rem, 1rem + 2vw, 2.5rem);
    width: auto;
    flex-shrink: 0;
    margin-right: clamp(1.5rem, calc(2rem + 3vw), 4.5rem);
  }

  @keyframes scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-50%);
    }
  }
</style>
