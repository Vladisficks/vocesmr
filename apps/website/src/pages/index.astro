---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import OurClients from "../components/OurClients.astro";
import ContactUs from "../components/ContactUs.astro";
import WhyUs from "../components/WhyUs.astro";
---

<BaseLayout
  title="Voces MR - Agencia de Locutores"
  description="VocesMR es una agencia de locutores comerciales. Nuestro objetivo es brindarle al cliente los mejores locutores de latinoamerica"
>
  <main>
    <Hero />
    <WhyUs />
    <section id="ourServices">
      <p>
        Lorem ipsum dolor sit amet, consectetur adipisicing elit. Pariatur
        labore eveniet velit in sapiente ratione, explicabo iure neque
        accusantium natus debitis. Accusamus sequi optio, ea incidunt quod
        ratione a ab.
      </p>
    </section>
    <section id="previewTalents">
      <p>
        Lorem ipsum dolor sit amet consectetur adipisicing elit. Distinctio
        ipsum modi, dolorum cupiditate praesentium sequi eveniet sapiente
        impedit minus, tempore numquam ab, nemo deserunt laudantium nostrum.
        Repellendus quis dolores blanditiis.
      </p>
    </section>
    <OurClients />
    <ContactUs />
  </main>
</BaseLayout>

<style>
  .brands {
    background-color: var(--accent-primary);
  }
</style>
